# ──────────────────────────────────────────────
# Supabase Edge Functions (supabase/.env.local)
# ──────────────────────────────────────────────

# Todoist OAuth App credentials
# Get these from: https://developer.todoist.com/appconsole.html
TODOIST_CLIENT_ID=
TODOIST_CLIENT_SECRET=

# Default AI provider (auto-detects Anthropic by URL; otherwise uses OpenAI-compatible format)
# Users can override these in their settings
DEFAULT_AI_BASE_URL=https://api.anthropic.com/v1
DEFAULT_AI_API_KEY=
DEFAULT_AI_MODEL=claude-opus-4-6

# Fallback AI model when the default model is overloaded (HTTP 529/503)
# Only used with Anthropic provider + default model; leave unset to use default, set empty to disable
DEFAULT_AI_FALLBACK_MODEL=claude-sonnet-4-6

# Brave Search API key (optional — enables web search tool)
# Get one at: https://brave.com/search/api/
DEFAULT_BRAVE_API_KEY=

# Frontend URL (for OAuth redirect)
PUBLIC_SITE_URL=http://localhost:5173

# Encryption key for sensitive columns (AES-256-GCM, 32 bytes base64-encoded)
# Generate: deno -e "console.log(btoa(String.fromCharCode(...crypto.getRandomValues(new Uint8Array(32)))))"
ENCRYPTION_KEY=

# Sentry DSN (optional — enables error tracking)
SENTRY_DSN=

# Stripe billing (monetization sub-project B)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO_MONTHLY=price_...
APP_URL=http://localhost:5173

# ──────────────────────────────────────────────
# Frontend (frontend/.env.local)
# ──────────────────────────────────────────────

# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<from supabase start output>
# VITE_TODOIST_CLIENT_ID=<same as TODOIST_CLIENT_ID above>
# VITE_SENTRY_DSN=<optional — enables frontend error tracking>
